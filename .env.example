# Instructions to create an AI Gateway API key here: https://vercel.com/ai-gateway
# API key required for non-Vercel deployments
# For Vercel deployments, OIDC tokens are used automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****


# Supabase project credentials
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xtuvxkwljdqjttypjwxt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostgreSQL connection — use the Supabase connection pooler URL
# Found under Project Settings > Database > Connection string (pooling mode)
POSTGRES_URL=****


# Instructions to create a Redis store here:
# https://vercel.com/docs/redis
REDIS_URL=****

# Resend — used for sending invitation emails
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
# The "from" address for outgoing emails (must use a verified domain in Resend)
RESEND_FROM_EMAIL=Chatbot <noreply@yourdomain.com>

# Public application URL — used for constructing invitation links
NEXT_PUBLIC_APP_URL=http://localhost:3000
